# ══════════════════════════════════════════════════════════
#  ABBY CAKE AND BITES — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env file to version control!
# ══════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Frontend URL (for CORS) ─────────────────────────────────
# Your Vercel / Netlify / custom domain URL
# Use * for development (allows all origins — not for production!)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ── MongoDB ─────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://abbyadmin:YOUR_PASSWORD@cluster0.abcde.mongodb.net/abby_bakery?retryWrites=true&w=majority

# ── JWT Authentication ──────────────────────────────────────
# Use a long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret_string_at_least_64_characters
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer via Gmail) ────────────────────────────
# EMAIL_USER: The Gmail account you'll send FROM
# EMAIL_PASS: Gmail App Password (NOT your regular Gmail password)
#
# How to create a Gmail App Password:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification (required)
#   3. Go to Security → 2-Step Verification → App passwords
#   4. Create a new app password for "Mail" on "Other device"
#   5. Copy the 16-character password here
#
EMAIL_USER=your.gmail.address@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── Bakery Owner Email ──────────────────────────────────────
# Where order notifications will be sent
OWNER_EMAIL=lyndagift06@gmail.com

# ── Anthropic AI API ────────────────────────────────────────
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ── Admin Default Password ──────────────────────────────────
# Used only by the seed script (utils/seed.js)
# Change this after your first login!
ADMIN_DEFAULT_PASSWORD=AbbyCakes2024!
